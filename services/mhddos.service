[Unit]
Description=MHDDOS
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=cdss
Group=cdss
Restart=on-failure
RestartSec=10
ExecStart=placeholder
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log /tmp

StandardOutput=append:/var/log/cdss.log
StandardError=append:/var/log/cdss.log

[Install]
WantedBy=multi-user.target
