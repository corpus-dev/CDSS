#!/usr/bin/env bash
set -uo pipefail

export SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../" && pwd)"
export INSTALL_DIR="/opt/cybercorps"
OSARCH=$(uname -m)

GREEN='\033[0;32m'
GRAY='\033[0;37m'
RED='\033[0;31m'
NC='\033[0m'
ORANGE='\033[0;33m'

trans() { echo "$@"; }

source "$SCRIPT_DIR/utils/platform_matrix.sh"

if [[ -f "$SCRIPT_DIR/utils/translate.sh" ]]; then
  source "$SCRIPT_DIR/utils/translate.sh"
else
  trans() { echo "$@"; }
fi

require_privileges

localization_file=$(apply_localization "$@")
if [[ -n "$localization_file" ]]; then
  source "$localization_file"
fi


export TOOL_DIR="$SCRIPT_DIR/bin"

reload_runtime_files() {
  local runtime_files=(
    "$SCRIPT_DIR/utils/definitions.sh"
    "$SCRIPT_DIR/utils/dialog.sh"
    "$SCRIPT_DIR/utils/datapatch.sh"
    "$SCRIPT_DIR/utils/updater.sh"
    "$SCRIPT_DIR/utils/scheduler.sh"
    "$SCRIPT_DIR/utils/port-extending.sh"
    "$SCRIPT_DIR/utils/fail2ban.sh"
    "$SCRIPT_DIR/utils/ufw.sh"
    "$SCRIPT_DIR/utils/mhddos.sh"
    "$SCRIPT_DIR/utils/distress.sh"
    "$SCRIPT_DIR/utils/x100.sh"
    "$SCRIPT_DIR/menu/menu_init.sh"
    "$SCRIPT_DIR/menu/ddos_tool_managment.sh"
    "$SCRIPT_DIR/menu/ddoss.sh"
    "$SCRIPT_DIR/menu/autoloading.sh"
    "$SCRIPT_DIR/menu/security_configuration.sh"
    "$SCRIPT_DIR/menu/security_settings.sh"
    "$SCRIPT_DIR/menu/main_menu.sh"
  )
  local file

  for file in "${runtime_files[@]}"; do
    if [[ -f "$file" ]]; then
      source "$file"
    else
      echo -e "${RED}$(trans "Не знайдено файл '$file'.")${NC}"
    fi
  done
}

reload_runtime_files

truncate_large_cdss_log() {
  local log_file="/var/log/cdss.log"
  if [[ -f "$log_file" ]] && [[ "$(stat -c%s "$log_file" 2>/dev/null || echo 0)" -gt 314572800 ]]; then
    local archive_file="/var/log/cdss.log.archive.$(date +%s)"
    cp "$log_file" "$archive_file" 2>/dev/null || true
    chmod 600 "$archive_file" 2>/dev/null || true
    truncate -s 0 "$log_file"
  fi
}



if [ "${1:-}" = "--auto-install" ]; then
  truncate_large_cdss_log
  check_updates
  reload_runtime_files
  apply_patch "${SCRIPT_DIR}/services/EnvironmentFile"

  dist_id=$(get_distribution_id)
  dist_family=$(get_distribution_family)
  support_level=$(get_platform_support_level)

  if [[ "$support_level" == "unsupported" ]]; then
    echo -e "${RED}$(trans "Дистрибутив '$dist_id' не підтримується. Авто-інсталяція призупинена.")${NC}"
    exit 1
  fi

  if [[ "$support_level" == "partial" ]]; then
    echo -e "${ORANGE}$(trans "Дистрибутив '$dist_id' має partial support. Деякі функції можуть бути обмежені.")${NC}"
  fi

  install_fail2ban
  configure_fail2ban
  install_ufw
  install_distress

  is_not_arm_arch
  if [[ $? == 1 ]]; then
    confirm_dialog "$(trans "MHDDOS встановлено. Активувати атаку?")"
    mhddos_run
    mhddos_auto_enable
  fi
  extend_ports
  get_ddoss_status
elif [ "${1:-}" = "--restore" ]; then

  is_not_arm_arch
  if [[ $? == 1 ]]; then
  mhddos_stop
  mhddos_auto_disable >/dev/null 2>&1
  safe_remove_path "/tmp/_MEI*" || true
  fi

  distress_stop
  distress_auto_disable >/dev/null 2>&1
  safe_remove_path "/tmp/distress" || true
  truncate_large_cdss_log

  if ! assert_safe_script_dir "${SCRIPT_DIR}"; then
    echo -e "${RED}$(trans "SCRIPT_DIR не пройшов перевірку безпеки. Restore скасовано.")${NC}"
    exit 1
  fi

  backup_file=$(mktemp)
  if [[ -f "${SCRIPT_DIR}/services/EnvironmentFile" ]]; then
    cp "${SCRIPT_DIR}/services/EnvironmentFile" "$backup_file"
    echo -e "${GREEN}$(trans "Backup EnvironmentFile створено.")${NC}"
  fi

  install_url="https://raw.githubusercontent.com/corpus-dev/CDSS/main/install.sh"
  tmp_install=$(mktemp)

  if ! curl -sL --fail --location --show-error --connect-timeout 10 --max-time 60 "$install_url" -o "$tmp_install"; then
    echo -e "${RED}$(trans "Не вдалося завантажити інсталятор. Перевірте мережу.")${NC}"
    rm -f "$backup_file" 2>/dev/null
    exit 1
  fi

  if [[ ! -s "$tmp_install" ]]; then
    echo -e "${RED}$(trans "Завантажений файл порожній. Restore скасовано.")${NC}"
    rm -f "$tmp_install" "$backup_file" 2>/dev/null
    exit 1
  fi

  local install_checksum
  install_checksum=$(sha256sum "$tmp_install" | cut -d' ' -f1)
  echo "$(date '+%Y-%m-%d %H:%M:%S') [CDSS] install.sh checksum: $install_checksum" >> /var/log/cdss.log 2>/dev/null || true

  bash "$tmp_install"
  install_exit=$?

  if [[ $install_exit -ne 0 ]]; then
    echo -e "${RED}$(trans "Інсталятор завершився з помилкою. Backup збережено: $backup_file")${NC}"
    rm -f "$tmp_install" 2>/dev/null
    exit 1
  fi

  if ! safe_remove_cdss_dir "${SCRIPT_DIR}"; then
    echo -e "${RED}$(trans "Не вдалося безпечно видалити стару інсталяцію. Restore скасовано.")${NC}"
    rm -f "$backup_file" 2>/dev/null
    exit 1
  fi

  if [[ -f "$backup_file" ]]; then
    new_script_dir="$INSTALL_DIR"
    if [[ -d "$new_script_dir" ]]; then
      if [[ -f "${new_script_dir}/services/EnvironmentFile" ]]; then
        cp "$backup_file" "${new_script_dir}/services/EnvironmentFile"
        echo -e "${GREEN}$(trans "Backup відновлено у новій інсталяції.")${NC}"
      else
        mkdir -p "${new_script_dir}/services"
        cp "$backup_file" "${new_script_dir}/services/EnvironmentFile"
        echo -e "${GREEN}$(trans "Backup відновлено у новій інсталяції.")${NC}"
      fi
    fi
    rm -f "$backup_file" 2>/dev/null
  fi

  rm -f "$tmp_install" 2>/dev/null
elif [ "${1:-}" = "config" ]; then
  clear
  cat "${SCRIPT_DIR}"/services/EnvironmentFile && echo ""
elif [ "${1:-}" = "--uninstall" ]; then
  if ! assert_safe_script_dir "${SCRIPT_DIR}"; then
    echo -e "${RED}$(trans "SCRIPT_DIR не пройшов перевірку безпеки. Uninstall скасовано.")${NC}"
    exit 1
  fi

  backup_file=$(mktemp)
  if [[ -f "${SCRIPT_DIR}/services/EnvironmentFile" ]]; then
    cp "${SCRIPT_DIR}/services/EnvironmentFile" "$backup_file"
    echo -e "${GREEN}$(trans "Backup EnvironmentFile створено перед видаленням.")${NC}"
  fi

  mhddos_stop
  mhddos_auto_disable >/dev/null 2>&1
  distress_stop
  distress_auto_disable >/dev/null 2>&1

  init_system=$(get_init_system)
  if [[ "$init_system" == "systemd" ]]; then
    sudo_or_root rm -f /etc/systemd/system/distress.service
    sudo_or_root rm -f /etc/systemd/system/mhddos.service
    sudo_or_root rm -f /etc/systemd/system/x100.service
  fi

  sudo_or_root rm -f /usr/local/bin/cdss
  cleanup_all_cdss_crons
  truncate_large_cdss_log

  if ! safe_remove_cdss_dir "${SCRIPT_DIR}"; then
    echo -e "${RED}$(trans "Не вдалося видалити інсталяцію. Backup збережено: $backup_file")${NC}"
    echo -e "${RED}$(trans "CDSS все ще встановлено. Спробуйте вручну.")${NC}"
    exit 1
  fi

  if [[ -f "$backup_file" ]]; then
    echo -e "${GREEN}$(trans "Backup збережено у: $backup_file")${NC}"
  fi

  echo -e "${GREEN}$(trans "CDSS успішно видалено")${NC}"
else
  check_updates
  reload_runtime_files
  apply_patch "${SCRIPT_DIR}/services/EnvironmentFile"
  main_menu
fi
